# ─── Supabase ────────────────────────────────────────────────
# Estas claves las encuentras en: supabase.com → tu proyecto → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Autenticación del panel admin ───────────────────────────
# Pon aquí la contraseña que usará la dueña del salón para entrar al panel
ADMIN_PASSWORD=mi_contrasena_segura_aqui

# ─── Secreto para firmar las sesiones ────────────────────────
# Genera una cadena aleatoria larga (mín. 32 caracteres)
# Puedes usar: openssl rand -base64 32
JWT_SECRET=una_cadena_muy_larga_y_aleatoria_aqui_de_al_menos_32_caracteres
